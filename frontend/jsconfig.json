{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/components/*": ["src/components/*"],
      "@/lib/*": ["src/lib/*"],
      "@/hooks/*": ["src/hooks/*"],
      "@/components/ui/*": ["src/components/ui/*"],
      "@/lib/utils/*": ["src/lib/utils/*"]
    },
    "jsx": "react-jsx"
  },
  "exclude": ["node_modules"]
}
